#include <stdio.h>

#define NMAX 10

int input(int *a);
void output(int *a);
void sort(int *a);

int main() {
  int data[NMAX];

  if (input(data) == 0) {
    sort(data);
    output(data);
  } else {
    printf("n/a");
  }

  return 0;
}

int input(int *a) {
  int error = 0;
  char c;

  for (int i = 0; i < NMAX && !error; i++) {
    if (i == NMAX - 1) {
      // Для последнего элемента проверяем корректный конец строки
      if (scanf("%d%c", (a + i), &c) != 2 || (c != '\n' && c != ' ')) {
        error = 1;
      }
    } else {
      if (scanf("%d", (a + i)) != 1) {
        error = 1;
      }
    }
  }

  return error;
}

void sort(int *a) {
  for (int i = 0; i < NMAX - 1; i++) {
    for (int j = 0; j < NMAX - i - 1; j++) {
      // Используем адресную арифметику *(a + j) вместо индексов
      if (*(a + j) > *(a + j + 1)) {
        int tmp = *(a + j);
        *(a + j) = *(a + j + 1);
        *(a + j + 1) = tmp;
      }
    }
  }
}

void output(int *a) {
  for (int i = 0; i < NMAX; i++) {
    printf("%d", *(a + i));
    if (i < NMAX - 1) {
      printf(" ");
    }
  }
}

